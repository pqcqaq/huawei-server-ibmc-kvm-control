<Application x:Class="IbmcKvm.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:IbmcKvm.App"
             ShutdownMode="OnLastWindowClose">
    <Application.Resources>
        <SolidColorBrush x:Key="CanvasBrush" Color="#F2F1ED" />
        <SolidColorBrush x:Key="InkBrush" Color="#18211E" />
        <SolidColorBrush x:Key="MutedBrush" Color="#66716C" />
        <SolidColorBrush x:Key="LineBrush" Color="#D4D6D1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#159B65" />
        <SolidColorBrush x:Key="DangerBrush" Color="#C64A40" />

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="#FAFAF7" />
            <Setter Property="BorderBrush" Value="#BBC0BB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="#FAFAF7" />
            <Setter Property="BorderBrush" Value="#BBC0BB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#E2E3DE" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="#C6CAC5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#0D8153" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="#26312D" />
            <Setter Property="BorderBrush" Value="#3E4A46" />
            <Setter Property="Foreground" Value="#EDF2EF" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>

        <Style x:Key="OverlayToolButton" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#EDF2EF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#3A4642" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#4A5752" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayToggleButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#EDF2EF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonSurface" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#3A4642" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#159B65" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#4A5752" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
