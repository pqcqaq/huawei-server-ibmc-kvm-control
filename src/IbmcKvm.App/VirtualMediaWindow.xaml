<Window x:Class="IbmcKvm.App.VirtualMediaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="虚拟媒体"
        Width="940" Height="650" MinWidth="820" MinHeight="580"
        Background="#F2F1ED"
        WindowStartupLocation="CenterOwner"
        Closed="Window_Closed">
    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#66716C" />
            <Setter Property="Margin" Value="0,14,0,5" />
        </Style>
        <Style x:Key="MediaButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#18211E" BorderBrush="#33403B" BorderThickness="0,0,0,1">
            <DockPanel Margin="18,0,12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE958;" FontFamily="Segoe Fluent Icons" FontSize="18"
                               Foreground="#49C98A" Margin="0,0,10,0" />
                    <TextBlock Text="虚拟媒体" FontFamily="Bahnschrift SemiBold" FontSize="18"
                               Foreground="#F2F5F3" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ReconnectButton" Style="{StaticResource ToolButton}"
                            Click="ReconnectButton_Click" ToolTip="重新连接已挂载介质">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" Foreground="White" FontSize="14" />
                    </Button>
                    <Button x:Name="RefreshDrivesButton" Style="{StaticResource ToolButton}"
                            Click="RefreshDrivesButton_Click" ToolTip="刷新物理驱动器">
                        <TextBlock Text="&#xE72D;" FontFamily="Segoe Fluent Icons" Foreground="White" FontSize="14" />
                    </Button>
                    <Button x:Name="UsbResetButton" Style="{StaticResource ToolButton}"
                            Click="UsbResetButton_Click" ToolTip="重置远端 USB 虚拟媒体设备">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE88E;" FontFamily="Segoe Fluent Icons" Foreground="#FFD27A" Margin="0,0,7,0" />
                            <TextBlock Text="USB reset" Foreground="White" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="24,22,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" Background="#DDE7E1" BorderBrush="#B9CEC0" BorderThickness="1">
                            <TextBlock Text="&#xEDA2;" FontFamily="Segoe Fluent Icons" FontSize="17"
                                       Foreground="#176845" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="11,0,0,0">
                            <TextBlock Text="虚拟软驱" FontFamily="Bahnschrift SemiBold" FontSize="17" />
                            <TextBlock x:Name="FloppyStatusText" Text="未挂载" FontSize="10" Foreground="#66716C" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="来源" Style="{StaticResource SectionLabel}" />
                    <ComboBox x:Name="FloppySourceComboBox" SelectedIndex="0" SelectionChanged="SourceComboBox_SelectionChanged">
                        <ComboBoxItem Content="软盘镜像 (.img)" Tag="Image" />
                        <ComboBoxItem Content="物理软驱" Tag="PhysicalDrive" />
                    </ComboBox>

                    <Grid x:Name="FloppyPathPanel">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="FloppyPathTextBox" Grid.Column="0" Margin="0,14,6,0" />
                        <Button Grid.Column="1" Margin="0,14,0,0" Style="{StaticResource BaseButton}" Padding="0"
                                Click="BrowseFloppyButton_Click" ToolTip="选择软盘镜像">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons" FontSize="15" />
                        </Button>
                    </Grid>

                    <ComboBox x:Name="FloppyDriveComboBox" Margin="0,14,0,0" Visibility="Collapsed"
                              DisplayMemberPath="DisplayName" />
                    <CheckBox x:Name="FloppyWriteProtectCheckBox" Content="写保护" IsChecked="True"
                              Margin="0,16,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <ProgressBar x:Name="FloppyProgressBar" Height="3" Minimum="0" Maximum="100"
                                 Visibility="Collapsed" Margin="0,0,0,14" />
                    <WrapPanel>
                        <Button x:Name="MountFloppyButton" Content="挂载" Style="{StaticResource PrimaryButton}"
                                MinWidth="92" Margin="0,0,8,8" Click="MountFloppyButton_Click" />
                        <Button x:Name="EjectFloppyButton" Content="弹出" Style="{StaticResource MediaButton}"
                                IsEnabled="False" Margin="0,0,8,8" Click="EjectFloppyButton_Click" />
                        <Button x:Name="CreateFloppyImageButton" Content="制作镜像" Style="{StaticResource MediaButton}"
                                Visibility="Collapsed" Margin="0,0,0,8" Click="CreateFloppyImageButton_Click" />
                    </WrapPanel>
                </StackPanel>
            </Grid>

            <Border Grid.Column="1" Background="#D4D6D1" />

            <Grid Grid.Column="2" Margin="24,22,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" Background="#E8E2D5" BorderBrush="#CFC2A4" BorderThickness="1">
                            <TextBlock Text="&#xE958;" FontFamily="Segoe Fluent Icons" FontSize="17"
                                       Foreground="#806324" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="11,0,0,0">
                            <TextBlock Text="虚拟光驱" FontFamily="Bahnschrift SemiBold" FontSize="17" />
                            <TextBlock x:Name="OpticalStatusText" Text="未挂载" FontSize="10" Foreground="#66716C" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="来源" Style="{StaticResource SectionLabel}" />
                    <ComboBox x:Name="OpticalSourceComboBox" SelectedIndex="0" SelectionChanged="SourceComboBox_SelectionChanged">
                        <ComboBoxItem Content="光盘镜像 (.iso)" Tag="Image" />
                        <ComboBoxItem Content="物理光驱" Tag="PhysicalDrive" />
                        <ComboBoxItem Content="本地目录" Tag="Directory" />
                    </ComboBox>

                    <Grid x:Name="OpticalPathPanel">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="OpticalPathTextBox" Grid.Column="0" Margin="0,14,6,0" />
                        <Button Grid.Column="1" Margin="0,14,0,0" Style="{StaticResource BaseButton}" Padding="0"
                                Click="BrowseOpticalButton_Click" ToolTip="选择镜像或目录">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons" FontSize="15" />
                        </Button>
                    </Grid>

                    <ComboBox x:Name="OpticalDriveComboBox" Margin="0,14,0,0" Visibility="Collapsed"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <ProgressBar x:Name="OpticalProgressBar" Height="3" Minimum="0" Maximum="100"
                                 Visibility="Collapsed" Margin="0,0,0,14" />
                    <WrapPanel>
                        <Button x:Name="MountOpticalButton" Content="挂载" Style="{StaticResource PrimaryButton}"
                                MinWidth="92" Margin="0,0,8,8" Click="MountOpticalButton_Click" />
                        <Button x:Name="EjectOpticalButton" Content="弹出" Style="{StaticResource MediaButton}"
                                IsEnabled="False" Margin="0,0,8,8" Click="EjectOpticalButton_Click" />
                        <Button x:Name="CreateOpticalImageButton" Content="制作镜像" Style="{StaticResource MediaButton}"
                                Visibility="Collapsed" Margin="0,0,0,8" Click="CreateOpticalImageButton_Click" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#DADCD7" BorderBrush="#C1C5C0" BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <TextBlock x:Name="OperationStatusText" Text="就绪" VerticalAlignment="Center"
                           Foreground="#44504B" FontSize="10" />
                <TextBlock DockPanel.Dock="Right" x:Name="CapabilityText" Text="VMM 未查询"
                           VerticalAlignment="Center" Foreground="#68736E" FontSize="10" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
