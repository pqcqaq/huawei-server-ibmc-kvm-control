<Window x:Class="IbmcKvm.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 iBMC KVM" Width="620" Height="500" MinWidth="580" MinHeight="460"
        ResizeMode="CanResizeWithGrip" Background="{StaticResource CanvasBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="118" />
            <RowDefinition Height="*" />
            <RowDefinition Height="58" />
        </Grid.RowDefinitions>
        <Border Background="#18211E">
            <StackPanel Margin="28,22">
                <TextBlock Text="iBMC KVM" Foreground="White" FontFamily="Bahnschrift SemiBold" FontSize="26" />
                <TextBlock x:Name="VersionText" Foreground="#9FADA6" FontSize="11" Margin="0,6,0,0" />
                <TextBlock Text="Windows x64 remote console client" Foreground="#C4CEC9" FontSize="10" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,22">
                <TextBlock Text="协议兼容性" FontSize="16" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" LineHeight="21" Margin="0,10,0,0"
                           Text="支持现代 iBMC、旧版 iBMC RMCP+/OEM 与 iMana 会话配置；包含明文或加密 KVM、虚拟媒体、14 槽位机箱、相对/绝对输入、DQT 清晰度和 8/7/6/4 位颜色。具体固件仍以运行时能力协商为准。" />
                <TextBlock Text="安全边界" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,0" />
                <TextBlock TextWrapping="Wrap" LineHeight="21" Margin="0,10,0,0"
                           Text="不安装全局键盘或鼠标钩子；凭据使用 Windows 当前用户 DPAPI 加密；会话密钥不写日志；证书信任显式、按主机范围保存并可撤销；网络、解码与文件队列均有界且可取消。" />
                <TextBlock Text="实现" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,0" />
                <TextBlock Text=".NET 9 · WPF · x64" Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <Button Content="关闭" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
                    VerticalAlignment="Center" Margin="0,0,20,0" MinWidth="88" IsCancel="True" />
        </Border>
    </Grid>
</Window>
