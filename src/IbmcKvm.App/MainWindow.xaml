<Window x:Class="IbmcKvm.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iBMC Remote Console"
        Width="1280" Height="800" MinWidth="760" MinHeight="480"
        Background="#090B0A"
        WindowStartupLocation="CenterScreen"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated"
        Closed="Window_Closed"
        MouseLeave="Window_MouseLeave">
    <Grid x:Name="ConsoleRoot" Background="#090B0A" MouseMove="ConsoleRoot_MouseMove">
        <Grid x:Name="VideoHost" Focusable="True"
              PreviewKeyDown="VideoHost_PreviewKeyDown" PreviewKeyUp="VideoHost_PreviewKeyUp"
              GotKeyboardFocus="VideoHost_GotKeyboardFocus" LostKeyboardFocus="VideoHost_LostKeyboardFocus"
              MouseEnter="VideoHost_MouseEnter" MouseLeave="VideoHost_MouseLeave"
              PreviewMouseDown="VideoHost_PreviewMouseDown" PreviewMouseUp="VideoHost_PreviewMouseUp"
              PreviewMouseMove="VideoHost_PreviewMouseMove" PreviewMouseWheel="VideoHost_PreviewMouseWheel">
            <Image x:Name="RemoteImage" Stretch="Uniform" SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Border x:Name="ViewerOverlay" Background="#F2090B0A" IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE968;" FontFamily="Segoe Fluent Icons" FontSize="36"
                               Foreground="#718079" HorizontalAlignment="Center" />
                    <TextBlock Text="正在等待远程画面" FontFamily="Bahnschrift SemiBold" FontSize="18"
                               Foreground="#DCE4E0" HorizontalAlignment="Center" Margin="0,14,0,0" />
                    <TextBlock x:Name="ConnectedEndpointText" Foreground="#7F8D86" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12"
                    Background="#D91A211E" BorderBrush="#46534E" BorderThickness="1"
                    CornerRadius="3" Padding="9,6" IsHitTestVisible="False">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="InputStatusDot" Width="9" Height="9" Fill="#77827D" Margin="0,0,7,0" />
                    <TextBlock x:Name="InputStatusText" Text="已连接，等待视频" VerticalAlignment="Center"
                               Foreground="#E1E8E4" FontSize="10" />
                </StackPanel>
            </Border>

            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"
                    Background="#D91A211E" BorderBrush="#46534E" BorderThickness="1"
                    CornerRadius="3" Padding="9,6" IsHitTestVisible="False">
                <TextBlock x:Name="VideoMetricsText" Text="无视频信号" Foreground="#DDE5E1" FontSize="10" />
            </Border>

            <Border x:Name="StatusMessageBorder" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="12" Background="#E626312D" BorderBrush="#53615B" BorderThickness="1"
                    CornerRadius="3" Padding="12,6" IsHitTestVisible="False">
                <TextBlock x:Name="StatusMessageText" Text="已连接" Foreground="#E8EFEB" FontSize="10" />
            </Border>
        </Grid>

        <Border x:Name="ToolbarRevealZone" Height="12" VerticalAlignment="Top"
                Background="Transparent" Panel.ZIndex="20" MouseEnter="ToolbarRevealZone_MouseEnter" />

        <Border x:Name="FloatingToolbar" HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,14,0,0" Padding="5" Background="#F01D2522"
                BorderBrush="#53615B" BorderThickness="1" CornerRadius="4" Panel.ZIndex="30"
                MouseEnter="FloatingToolbar_MouseEnter" MouseLeave="FloatingToolbar_MouseLeave">
            <StackPanel Orientation="Horizontal">
                <ToggleButton x:Name="PinToolbarButton" Style="{StaticResource OverlayToggleButton}"
                              IsChecked="True" Click="PinToolbarButton_Click"
                              ToolTip="取消固定，鼠标离开后自动隐藏">
                    <TextBlock Text="&#xE840;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="White" />
                </ToggleButton>

                <Border Width="1" Height="24" Background="#53615B" Margin="5,7" />

                <Button x:Name="VirtualMediaButton" Style="{StaticResource OverlayToolButton}"
                        Click="VirtualMediaButton_Click" ToolTip="虚拟软驱与虚拟光驱">
                    <TextBlock Text="&#xE958;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button x:Name="ScreenshotButton" Style="{StaticResource OverlayToolButton}" IsEnabled="False"
                        Click="ScreenshotButton_Click" ToolTip="保存当前画面">
                    <TextBlock Text="&#xE722;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button Style="{StaticResource OverlayToolButton}" Click="CtrlAltDeleteButton_Click"
                        ToolTip="发送 Ctrl + Alt + Delete">
                    <TextBlock Text="&#xE765;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button Style="{StaticResource OverlayToolButton}" Click="ReleaseKeysButton_Click"
                        ToolTip="释放全部远程按键">
                    <TextBlock Text="&#xE8F5;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button x:Name="FullscreenButton" Style="{StaticResource OverlayToolButton}"
                        Click="FullscreenButton_Click" ToolTip="切换全屏">
                    <TextBlock Text="&#xE740;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button x:Name="PowerMenuButton" Style="{StaticResource OverlayToolButton}"
                        Click="PowerMenuButton_Click" ToolTip="电源操作">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="开机" Click="PowerOnButton_Click" />
                            <MenuItem Header="正常关机" Click="GracefulPowerOffButton_Click" />
                            <Separator />
                            <MenuItem Header="重启" Click="RestartButton_Click" />
                            <MenuItem Header="强制关机" Click="PowerOffButton_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Text="&#xE7E8;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>

                <Border Width="1" Height="24" Background="#53615B" Margin="5,7" />

                <Button x:Name="DisconnectButton" Style="{StaticResource OverlayToolButton}"
                        Click="DisconnectButton_Click" ToolTip="关闭连接并返回登录">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="#F08B83" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
