<Window x:Class="IbmcKvm.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iBMC Remote Console"
        Width="1280" Height="800" MinWidth="980" MinHeight="540"
        Background="#090B0A"
        WindowStartupLocation="CenterScreen"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated"
        Closed="Window_Closed"
        MouseLeave="Window_MouseLeave">
    <Grid x:Name="ConsoleRoot" Background="#090B0A" MouseMove="ConsoleRoot_MouseMove">
        <Grid x:Name="VideoHost" Focusable="True"
              PreviewKeyDown="VideoHost_PreviewKeyDown" PreviewKeyUp="VideoHost_PreviewKeyUp"
              GotKeyboardFocus="VideoHost_GotKeyboardFocus" LostKeyboardFocus="VideoHost_LostKeyboardFocus"
              MouseEnter="VideoHost_MouseEnter" MouseLeave="VideoHost_MouseLeave"
              PreviewMouseDown="VideoHost_PreviewMouseDown" PreviewMouseUp="VideoHost_PreviewMouseUp"
              PreviewMouseMove="VideoHost_PreviewMouseMove" PreviewMouseWheel="VideoHost_PreviewMouseWheel">
            <Image x:Name="RemoteImage" Stretch="Uniform" SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Grid x:Name="SplitVideoGrid" Visibility="Collapsed" Background="#090B0A"
                  IsHitTestVisible="False" />

            <Border x:Name="ViewerOverlay" Background="#F2090B0A" IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE968;" FontFamily="Segoe Fluent Icons" FontSize="36"
                               Foreground="#718079" HorizontalAlignment="Center" />
                    <TextBlock Text="正在等待远程画面" FontFamily="Bahnschrift SemiBold" FontSize="18"
                               Foreground="#DCE4E0" HorizontalAlignment="Center" Margin="0,14,0,0" />
                    <TextBlock x:Name="ConnectedEndpointText" Foreground="#7F8D86" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12"
                    Background="#D91A211E" BorderBrush="#46534E" BorderThickness="1"
                    CornerRadius="3" Padding="9,6" IsHitTestVisible="False">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="InputStatusDot" Width="9" Height="9" Fill="#77827D" Margin="0,0,7,0" />
                    <TextBlock x:Name="InputStatusText" Text="已连接，等待视频" VerticalAlignment="Center"
                               Foreground="#E1E8E4" FontSize="10" />
                </StackPanel>
            </Border>

            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"
                    Background="#D91A211E" BorderBrush="#46534E" BorderThickness="1"
                    CornerRadius="3" Padding="9,6" IsHitTestVisible="False">
                <TextBlock x:Name="VideoMetricsText" Text="无视频信号" Foreground="#DDE5E1" FontSize="10" />
            </Border>

            <Border x:Name="StatusMessageBorder" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="12" Background="#E626312D" BorderBrush="#53615B" BorderThickness="1"
                    CornerRadius="3" Padding="12,6" IsHitTestVisible="False">
                <TextBlock x:Name="StatusMessageText" Text="已连接" Foreground="#E8EFEB" FontSize="10" />
            </Border>
        </Grid>

        <Border x:Name="BladeTabsBar" HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,104,0,0" Padding="4" Background="#F01D2522"
                BorderBrush="#53615B" BorderThickness="1" CornerRadius="4"
                Panel.ZIndex="24" Visibility="Collapsed">
            <ListBox x:Name="BladeTabsList" Background="Transparent" BorderThickness="0"
                     SelectionChanged="BladeTabsList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="7,2" MinWidth="64">
                            <TextBlock Text="{Binding Name}" Foreground="#EDF2EF" FontSize="11"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Status}" Foreground="#9DAAA4" FontSize="9"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border x:Name="ChassisPanel" Width="268" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Margin="12,104,0,56" Padding="10" Background="#F51A211E"
                BorderBrush="#53615B" BorderThickness="1" CornerRadius="4"
                Panel.ZIndex="26" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="机箱刀片" Foreground="#EDF2EF" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Style="{StaticResource OverlayToolButton}" Width="34" Height="30"
                            HorizontalAlignment="Right" DockPanel.Dock="Right"
                            Click="RefreshChassisButton_Click" ToolTip="刷新机箱状态">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="15" Foreground="White" />
                    </Button>
                </DockPanel>
                <ListBox x:Name="ChassisBladeList" Grid.Row="1" Background="#101512"
                         BorderBrush="#3D4944" BorderThickness="1"
                         SelectionChanged="ChassisBladeList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="42" Margin="5,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" Foreground="#E4EBE7" FontSize="11"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status}" Foreground="#AEBAB4" FontSize="10" />
                                    <TextBlock Text="{Binding Detail}" Foreground="#75827C" FontSize="9"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button x:Name="MonitorBladeButton" Style="{StaticResource OverlayToolButton}"
                            Click="MonitorBladeButton_Click" ToolTip="只读监视选中刀片" IsEnabled="False">
                        <TextBlock Text="&#xE890;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="White" />
                    </Button>
                    <Button x:Name="ConnectBladeButton" Style="{StaticResource OverlayToolButton}"
                            Click="ConnectBladeButton_Click" ToolTip="控制选中刀片" IsEnabled="False">
                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="White" />
                    </Button>
                    <Button x:Name="DisconnectBladeButton" Style="{StaticResource OverlayToolButton}"
                            Click="DisconnectBladeButton_Click" ToolTip="关闭当前刀片会话" IsEnabled="False">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#F08B83" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="ToolbarRevealZone" Height="18" VerticalAlignment="Top"
                Background="Transparent" Panel.ZIndex="40" MouseEnter="ToolbarRevealZone_MouseEnter">
            <Border x:Name="ToolbarHiddenHandle" Width="120" Height="7" VerticalAlignment="Top"
                    Margin="0,5,0,0" Background="#159B65" BorderBrush="#8FE0BC"
                    BorderThickness="1" CornerRadius="4" Opacity="0" Visibility="Collapsed"
                    IsHitTestVisible="False" />
        </Border>

        <Border x:Name="FloatingToolbar" HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,14,0,0" Padding="5" Background="#F01D2522"
                BorderBrush="#53615B" BorderThickness="1" CornerRadius="4" Panel.ZIndex="30"
                RenderTransformOrigin="0.5,0"
                MouseEnter="FloatingToolbar_MouseEnter" MouseLeave="FloatingToolbar_MouseLeave">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToolbarTranslateTransform" />
            </Border.RenderTransform>
            <StackPanel x:Name="ConsoleToolbarItems" Orientation="Horizontal">
                <ToggleButton x:Name="PinToolbarButton" Style="{StaticResource OverlayToggleButton}"
                              IsChecked="True" Click="PinToolbarButton_Click"
                              ToolTip="取消固定，鼠标离开后自动隐藏">
                    <TextBlock Text="&#xE840;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="White" />
                </ToggleButton>

                <Button x:Name="ChassisButton" Style="{StaticResource OverlayToolButton}"
                        Click="ChassisButton_Click" ToolTip="机箱与刀片" Visibility="Collapsed">
                    <TextBlock Text="&#xE950;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <ToggleButton x:Name="SplitViewButton" Style="{StaticResource OverlayToggleButton}"
                              Click="SplitViewButton_Click" ToolTip="四路只读分屏" Visibility="Collapsed">
                    <TextBlock Text="&#xECA5;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </ToggleButton>

                <Button x:Name="MouseModeButton" Style="{StaticResource OverlayToolButton}"
                        Click="ContextMenuButton_Click" ToolTip="鼠标模式">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="绝对" Tag="Absolute" IsCheckable="True"
                                      Click="MouseModeMenuItem_Click" />
                            <MenuItem Header="相对" Tag="Relative" IsCheckable="True"
                                      Click="MouseModeMenuItem_Click" />
                            <MenuItem Header="捕获" Tag="Captured" IsCheckable="True"
                                      Click="MouseModeMenuItem_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Text="&#xE7C9;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>

                <ToggleButton x:Name="ShowLocalPointerButton" Style="{StaticResource OverlayToggleButton}"
                              IsChecked="True" Click="ShowLocalPointerButton_Click"
                              ToolTip="显示本地鼠标指针">
                    <TextBlock Text="&#xE962;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="White" />
                </ToggleButton>
                <Button x:Name="SynchronizeMouseButton" Style="{StaticResource OverlayToolButton}"
                        Click="SynchronizeMouseButton_Click" ToolTip="同步远端鼠标位置">
                    <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="White" />
                </Button>

                <Button x:Name="VideoQualityButton" Style="{StaticResource OverlayToolButton}"
                        Click="ContextMenuButton_Click" ToolTip="图像清晰度">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="低 40" Tag="40" IsCheckable="True" Click="VideoQualityMenuItem_Click" />
                            <MenuItem Header="低 50" Tag="50" IsCheckable="True" Click="VideoQualityMenuItem_Click" />
                            <MenuItem Header="中 60" Tag="60" IsCheckable="True" Click="VideoQualityMenuItem_Click" />
                            <MenuItem Header="中 70" Tag="70" IsCheckable="True" Click="VideoQualityMenuItem_Click" />
                            <MenuItem Header="高 80" Tag="80" IsCheckable="True" Click="VideoQualityMenuItem_Click" />
                            <MenuItem Header="高 90" Tag="90" IsCheckable="True" Click="VideoQualityMenuItem_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Text="&#xE91B;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button x:Name="ColorDepthButton" Style="{StaticResource OverlayToolButton}"
                        Click="ContextMenuButton_Click" ToolTip="颜色位数">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="8-bit" Tag="2" IsCheckable="True" Click="ColorDepthMenuItem_Click" />
                            <MenuItem Header="7-bit" Tag="1" IsCheckable="True" Click="ColorDepthMenuItem_Click" />
                            <MenuItem Header="6-bit" Tag="0" IsCheckable="True" Click="ColorDepthMenuItem_Click" />
                            <MenuItem Header="4-bit" Tag="3" IsCheckable="True" Click="ColorDepthMenuItem_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Text="&#xE790;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>

                <Border Width="1" Height="24" Background="#53615B" Margin="5,7" />

                <Button x:Name="VirtualMediaButton" Style="{StaticResource OverlayToolButton}"
                        Click="VirtualMediaButton_Click" ToolTip="虚拟软驱与虚拟光驱">
                    <TextBlock Text="&#xE958;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button x:Name="RecordButton" Style="{StaticResource OverlayToolButton}"
                        Click="RecordButton_Click" ToolTip="开始本地录像">
                    <TextBlock Text="&#xE7C8;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="#F0C674" />
                </Button>
                <Button x:Name="ScreenshotButton" Style="{StaticResource OverlayToolButton}" IsEnabled="False"
                        Click="ScreenshotButton_Click" ToolTip="保存当前画面">
                    <TextBlock Text="&#xE722;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button x:Name="KeyboardMenuButton" Style="{StaticResource OverlayToolButton}"
                        Click="KeyboardMenuButton_Click" ToolTip="组合键与键盘布局">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Ctrl + Shift" Tag="CtrlShift" Click="PresetCombinationMenuItem_Click" />
                            <MenuItem Header="Ctrl + Esc" Tag="CtrlEscape" Click="PresetCombinationMenuItem_Click" />
                            <MenuItem Header="Ctrl + Alt + Delete" Tag="CtrlAltDelete" Click="PresetCombinationMenuItem_Click" />
                            <MenuItem Header="Alt + Tab" Tag="AltTab" Click="PresetCombinationMenuItem_Click" />
                            <MenuItem Header="Ctrl + Space" Tag="CtrlSpace" Click="PresetCombinationMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="自定义组合键…" Click="CustomCombinationMenuItem_Click" />
                            <MenuItem Header="重置远端键盘" Tag="KeyboardReset" Click="PresetCombinationMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="键盘布局">
                                <MenuItem x:Name="UsKeyboardMenuItem" Header="English (US)" Tag="UnitedStates"
                                          IsCheckable="True" IsChecked="True" Click="KeyboardLayoutMenuItem_Click" />
                                <MenuItem x:Name="JapaneseKeyboardMenuItem" Header="日本語" Tag="Japanese"
                                          IsCheckable="True" Click="KeyboardLayoutMenuItem_Click" />
                                <MenuItem x:Name="FrenchKeyboardMenuItem" Header="Français" Tag="French"
                                          IsCheckable="True" Click="KeyboardLayoutMenuItem_Click" />
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Text="&#xE765;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>

                <Grid Width="58" Height="30" Margin="2,4" ToolTip="远端 Num/Caps/Scroll Lock 状态">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="N" FontSize="8" Foreground="#AAB4AF" HorizontalAlignment="Center" />
                        <Ellipse x:Name="NumLockIndicator" Width="7" Height="7" Fill="#59635F" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="C" FontSize="8" Foreground="#AAB4AF" HorizontalAlignment="Center" />
                        <Ellipse x:Name="CapsLockIndicator" Width="7" Height="7" Fill="#59635F" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="S" FontSize="8" Foreground="#AAB4AF" HorizontalAlignment="Center" />
                        <Ellipse x:Name="ScrollLockIndicator" Width="7" Height="7" Fill="#59635F" Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
                <Button x:Name="ReleaseKeysButton" Style="{StaticResource OverlayToolButton}" Click="ReleaseKeysButton_Click"
                        ToolTip="释放全部远程按键">
                    <TextBlock Text="&#xE8F5;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button x:Name="FullscreenButton" Style="{StaticResource OverlayToolButton}"
                        Click="FullscreenButton_Click" ToolTip="切换全屏">
                    <TextBlock Text="&#xE740;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>
                <Button x:Name="PowerMenuButton" Style="{StaticResource OverlayToolButton}"
                        Click="PowerMenuButton_Click" ToolTip="电源操作">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="开机" Click="PowerOnButton_Click" />
                            <MenuItem Header="正常关机" Click="GracefulPowerOffButton_Click" />
                            <Separator />
                            <MenuItem Header="重启" Click="RestartButton_Click" />
                            <MenuItem Header="强制断电重启" Click="ForcedPowerCycleButton_Click" />
                            <MenuItem Header="强制关机" Click="PowerOffButton_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Text="&#xE7E8;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>

                <Button x:Name="HelpButton" Style="{StaticResource OverlayToolButton}"
                        Click="HelpButton_Click" ToolTip="帮助与关于">
                    <TextBlock Text="&#xE897;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="White" />
                </Button>

                <Border Width="1" Height="24" Background="#53615B" Margin="5,7" />

                <Button x:Name="DisconnectButton" Style="{StaticResource OverlayToolButton}"
                        Click="DisconnectButton_Click" ToolTip="关闭连接并返回登录">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="17" Foreground="#F08B83" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
