<Window x:Class="IbmcKvm.App.CertificateDecisionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="确认服务器证书" Width="650" Height="510" MinWidth="620" MinHeight="480"
        Background="{StaticResource CanvasBrush}" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
            <RowDefinition Height="64" />
        </Grid.RowDefinitions>
        <Border Background="#18211E">
            <DockPanel Margin="22,0">
                <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons" FontSize="24"
                           Foreground="#F0C674" VerticalAlignment="Center" Margin="0,0,14,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="服务器证书需要确认" FontSize="17" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="核对指纹后再发送登录凭据" FontSize="10" Foreground="#AAB6B0" Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>
        <Grid Grid.Row="1" Margin="24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="主题" Foreground="{StaticResource MutedBrush}" Margin="0,0,12,12" />
            <TextBlock x:Name="SubjectText" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,12" />
            <TextBlock Grid.Row="1" Text="颁发者" Foreground="{StaticResource MutedBrush}" Margin="0,0,12,12" />
            <TextBlock x:Name="IssuerText" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,12" />
            <TextBlock Grid.Row="2" Text="有效期" Foreground="{StaticResource MutedBrush}" Margin="0,0,12,12" />
            <TextBlock x:Name="ValidityText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" />
            <TextBlock Grid.Row="3" Text="验证状态" Foreground="{StaticResource MutedBrush}" Margin="0,0,12,12" />
            <TextBlock x:Name="PolicyText" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,12" />
            <TextBlock Grid.Row="4" Text="SHA-256" Foreground="{StaticResource MutedBrush}" Margin="0,0,12,0" />
            <TextBox x:Name="FingerprintText" Grid.Row="4" Grid.Column="1" IsReadOnly="True"
                     FontFamily="Cascadia Mono" FontSize="11" TextWrapping="Wrap" Height="76"
                     VerticalScrollBarVisibility="Auto" />
        </Grid>
        <Border Grid.Row="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0">
                <Button Content="取消" Style="{StaticResource BaseButton}" MinWidth="82" Margin="0,0,8,0"
                        IsCancel="True" />
                <Button Content="仅本次信任" Style="{StaticResource BaseButton}" MinWidth="110" Margin="0,0,8,0"
                        Click="TrustSessionButton_Click" />
                <Button Content="记住此服务器" Style="{StaticResource PrimaryButton}" MinWidth="118"
                        Click="TrustServerButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
