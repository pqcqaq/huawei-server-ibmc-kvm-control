<Window x:Class="IbmcKvm.App.CustomKeyCombinationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="自定义组合键" Width="560" Height="400"
        MinWidth="520" MinHeight="380" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" Background="#111714" ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="自定义组合键" FontFamily="Bahnschrift SemiBold" FontSize="20"
                   Foreground="#F0F4F2" />
        <TextBlock Grid.Row="1" Margin="0,6,0,18" Foreground="#9EAAA4" FontSize="12"
                   Text="选择最多六个 HID 按键。发送后会自动释放全部按键。" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="14" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ComboBox x:Name="Key1ComboBox" Grid.Row="0" Grid.Column="0"
                      DisplayMemberPath="Label" SelectedValuePath="Usage" />
            <ComboBox x:Name="Key2ComboBox" Grid.Row="0" Grid.Column="2"
                      DisplayMemberPath="Label" SelectedValuePath="Usage" />
            <ComboBox x:Name="Key3ComboBox" Grid.Row="2" Grid.Column="0"
                      DisplayMemberPath="Label" SelectedValuePath="Usage" />
            <ComboBox x:Name="Key4ComboBox" Grid.Row="2" Grid.Column="2"
                      DisplayMemberPath="Label" SelectedValuePath="Usage" />
            <ComboBox x:Name="Key5ComboBox" Grid.Row="4" Grid.Column="0"
                      DisplayMemberPath="Label" SelectedValuePath="Usage" />
            <ComboBox x:Name="Key6ComboBox" Grid.Row="4" Grid.Column="2"
                      DisplayMemberPath="Label" SelectedValuePath="Usage" />
        </Grid>

        <TextBlock x:Name="ValidationText" Grid.Row="3" Margin="0,14,0,8"
                   Foreground="#F08B83" FontSize="11" MinHeight="16" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Width="88" Style="{StaticResource BaseButton}"
                    IsCancel="True" Margin="0,0,8,0" />
            <Button Content="发送" Width="88" Style="{StaticResource PrimaryButton}"
                    IsDefault="True" Click="SendButton_Click" />
        </StackPanel>
    </Grid>
</Window>
