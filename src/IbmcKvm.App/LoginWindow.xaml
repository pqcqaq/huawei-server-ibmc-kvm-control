<Window x:Class="IbmcKvm.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="连接 iBMC"
        Width="520" Height="690" MinWidth="520" MinHeight="690"
        MaxWidth="520" MaxHeight="690"
        ResizeMode="NoResize"
        Background="{StaticResource CanvasBrush}"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="142" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#18211E">
            <Grid>
            <StackPanel Margin="42,30,42,24">
                <StackPanel Orientation="Horizontal">
                    <Border Width="38" Height="38" Background="#159B65" CornerRadius="4" Margin="0,0,13,0">
                        <TextBlock Text="K" Foreground="White" FontFamily="Bahnschrift" FontWeight="Bold"
                                   FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="iBMC KVM" Foreground="#F3F7F5" FontFamily="Bahnschrift SemiBold"
                                   FontSize="21" />
                        <TextBlock Text="远程控制台" Foreground="#9DABA4" FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="连接服务器后将自动进入全屏控制界面"
                           Foreground="#B9C5BF" FontSize="11" Margin="1,18,0,0" />
            </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,18,22,0">
                    <ComboBox x:Name="LanguageComboBox" Width="112" Height="30" Margin="0,4,5,0"
                              DisplayMemberPath="DisplayName" SelectedValuePath="CultureName"
                              SelectionChanged="LanguageComboBox_SelectionChanged" ToolTip="界面语言" />
                    <Button x:Name="TrustManagerButton" Style="{StaticResource OverlayToolButton}"
                            Click="TrustManagerButton_Click" ToolTip="查看、导入或撤销证书信任">
                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="White" />
                    </Button>
                    <Button x:Name="HelpMenuButton" Style="{StaticResource OverlayToolButton}"
                            Click="HelpMenuButton_Click" ToolTip="帮助与关于">
                        <TextBlock Text="&#xE897;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="White" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="42,24,42,28">
            <Grid x:Name="ConnectionForm">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="iBMC 地址" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,5" />
                <TextBox Grid.Row="1" x:Name="AddressTextBox" ToolTip="主机名、IP 或 https://地址:端口" />

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="用户名" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,5" />
                        <TextBox x:Name="UserNameTextBox" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="密码" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,5" />
                        <PasswordBox x:Name="PasswordInput" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="3" Text="会话模式" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,12,0,5" />
                <ComboBox Grid.Row="4" x:Name="ModeComboBox" SelectedIndex="0">
                    <ComboBoxItem Content="共享控制" Tag="Shared" />
                    <ComboBoxItem Content="独占控制" Tag="Exclusive" />
                </ComboBox>

                <CheckBox Grid.Row="5" x:Name="TrustCheckBox" Margin="0,14,0,0"
                          VerticalContentAlignment="Center" Content="本次会话信任自签名证书" FontSize="12" />
                <TextBlock Grid.Row="6" Text="连接前显示服务器证书 SHA-256 指纹，由你确认后再发送凭据。"
                           Foreground="{StaticResource MutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="22,4,0,0" />

                <DockPanel Grid.Row="7" Margin="0,14,0,0" LastChildFill="True">
                    <Button x:Name="ClearSavedSettingsButton" DockPanel.Dock="Right" Content="清除"
                            Style="{StaticResource BaseButton}" Height="28" Padding="10,3"
                            Click="ClearSavedSettingsButton_Click" />
                    <CheckBox x:Name="RememberSettingsCheckBox" VerticalContentAlignment="Center"
                              Content="加密记住此连接" FontSize="12"
                              Unchecked="RememberSettingsCheckBox_Unchecked" />
                </DockPanel>
                <TextBlock Grid.Row="8" Text="连接成功后，凭据使用 Windows 当前用户加密并仅保存在本机。"
                           Foreground="{StaticResource MutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="22,4,0,0" />

                <Border Grid.Row="9" x:Name="LoginErrorBorder" Visibility="Collapsed"
                        Background="#F8E9E7" BorderBrush="#D9A49F" BorderThickness="1"
                        CornerRadius="3" Padding="10,8" Margin="0,14,0,0">
                    <TextBlock x:Name="LoginErrorText" Foreground="#A33830" FontSize="11" TextWrapping="Wrap" />
                </Border>

                <Button Grid.Row="10" x:Name="ConnectButton" Content="连接远程控制台"
                        Style="{StaticResource PrimaryButton}" Height="40" Margin="0,18,0,0"
                        IsDefault="True" Click="ConnectButton_Click" />
            </Grid>

            <Border x:Name="LoadingOverlay" Visibility="Collapsed" Background="#F2F1ED" Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="280">
                    <TextBlock Text="正在连接" FontFamily="Bahnschrift SemiBold" FontSize="18"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="LoadingStatusText" Text="正在建立安全连接"
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,8,0,16" />
                    <ProgressBar Height="4" IsIndeterminate="True" Foreground="{StaticResource AccentBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
