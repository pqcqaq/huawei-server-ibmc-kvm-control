<Application x:Class="IbmcKvm.Desktop.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="CanvasBrush" Color="#F2F1ED" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FAFAF7" />
    <SolidColorBrush x:Key="HeaderBrush" Color="#18211E" />
    <SolidColorBrush x:Key="AccentBrush" Color="#159B65" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#118356" />
    <SolidColorBrush x:Key="TextBrush" Color="#17201C" />
    <SolidColorBrush x:Key="MutedBrush" Color="#66716C" />
    <SolidColorBrush x:Key="LineBrush" Color="#C7CCC7" />
    <SolidColorBrush x:Key="ToolbarBrush" Color="#F01D2522" />
    <SolidColorBrush x:Key="ToolbarLineBrush" Color="#53615B" />
    <SolidColorBrush x:Key="ToolbarHoverBrush" Color="#34433D" />

    <StreamGeometry x:Key="IconPin">M10,1 L15,6 L13,8 L16,11 L14,13 L11,10 L8,13 L8,18 L6,20 L6,14 L2,10 L4,8 L7,11 L10,8 L8,6 Z</StreamGeometry>
    <StreamGeometry x:Key="IconMouse">M7,1 C4.2,1 2,3.2 2,6 L2,13 C2,16.3 4.7,19 8,19 C11.3,19 14,16.3 14,13 L14,6 C14,3.2 11.8,1 9,1 Z M8,2.5 L8,7 M3.5,8 L12.5,8</StreamGeometry>
    <StreamGeometry x:Key="IconSync">M4,6 C5.5,3.5 8.7,2.5 11.5,3.5 C13.1,4 14.4,5.1 15.3,6.5 L18,6.5 L14.6,10 L11.3,6.5 L13.5,6.5 C12.2,5.1 10.3,4.5 8.5,4.8 C6.8,5 5.4,6 4.5,7.3 Z M16,14 C14.5,16.5 11.3,17.5 8.5,16.5 C6.9,16 5.6,14.9 4.7,13.5 L2,13.5 L5.4,10 L8.7,13.5 L6.5,13.5 C7.8,14.9 9.7,15.5 11.5,15.2 C13.2,15 14.6,14 15.5,12.7 Z</StreamGeometry>
    <StreamGeometry x:Key="IconImage">M2,3 L18,3 L18,17 L2,17 Z M4,14 L8,10 L11,13 L13,11 L16,14 Z M13,6 A2,2 0 1 0 13,10 A2,2 0 1 0 13,6</StreamGeometry>
    <StreamGeometry x:Key="IconPalette">M10,2 C5.6,2 2,5.1 2,9 C2,13.4 5.8,17 10.2,17 L11.4,17 C12.5,17 13.1,15.7 12.4,14.9 C11.8,14.2 12.3,13 13.3,13 L15,13 C16.7,13 18,11.7 18,10 C18,5.6 14.4,2 10,2 Z M6,7 A1,1 0 1 0 6,9 A1,1 0 1 0 6,7 M10,5 A1,1 0 1 0 10,7 A1,1 0 1 0 10,5 M14,7 A1,1 0 1 0 14,9 A1,1 0 1 0 14,7</StreamGeometry>
    <StreamGeometry x:Key="IconDisc">M10,2 A8,8 0 1 0 10,18 A8,8 0 1 0 10,2 M10,7 A3,3 0 1 0 10,13 A3,3 0 1 0 10,7 M10,9.3 A0.7,0.7 0 1 0 10,10.7 A0.7,0.7 0 1 0 10,9.3</StreamGeometry>
    <StreamGeometry x:Key="IconRecord">M10,3 A7,7 0 1 0 10,17 A7,7 0 1 0 10,3 M10,6 A4,4 0 1 0 10,14 A4,4 0 1 0 10,6</StreamGeometry>
    <StreamGeometry x:Key="IconCamera">M3,6 L6,6 L7.5,4 L12.5,4 L14,6 L17,6 L17,16 L3,16 Z M10,8 A3,3 0 1 0 10,14 A3,3 0 1 0 10,8</StreamGeometry>
    <StreamGeometry x:Key="IconKeyboard">M2,5 L18,5 L18,15 L2,15 Z M4,7 L6,7 M8,7 L10,7 M12,7 L14,7 M16,7 L16.2,7 M4,10 L6,10 M8,10 L10,10 M12,10 L14,10 M16,10 L16.2,10 M5,13 L15,13</StreamGeometry>
    <StreamGeometry x:Key="IconRelease">M4,3 L4,10 M8,2 L8,9 M12,3 L12,10 M16,5 L16,12 C16,16 13,18 10,18 C6,18 3,15 2,11 L2,8 C2,7 3,6 4,7 L6,10</StreamGeometry>
    <StreamGeometry x:Key="IconFullscreen">M3,8 L3,3 L8,3 M12,3 L17,3 L17,8 M17,12 L17,17 L12,17 M8,17 L3,17 L3,12</StreamGeometry>
    <StreamGeometry x:Key="IconPower">M10,2 L10,10 M5,5 C2,7.5 2,12 5,15 C7.8,17.8 12.2,17.8 15,15 C18,12 18,7.5 15,5</StreamGeometry>
    <StreamGeometry x:Key="IconHelp">M7,7 C7,4 13,3.5 14,6 C15,8.5 11,9 10,11 L10,12 M10,15 L10,16</StreamGeometry>
    <StreamGeometry x:Key="IconDisconnect">M4,4 L16,16 M16,4 L4,16</StreamGeometry>
    <StreamGeometry x:Key="IconKey">M3,12 A4,4 0 1 0 9.8,9.2 L18,1 L19,2 L17,4 L19,6 L17,8 L15,6 L11.2,9.8 A4,4 0 0 0 3,12</StreamGeometry>
    <StreamGeometry x:Key="IconEye">M1,10 C4,5 7,3 10,3 C13,3 16,5 19,10 C16,15 13,17 10,17 C7,17 4,15 1,10 Z M10,7 A3,3 0 1 0 10,13 A3,3 0 1 0 10,7</StreamGeometry>
    <StreamGeometry x:Key="IconChassis">M2,3 L18,3 L18,17 L2,17 Z M5,6 L9,6 L9,9 L5,9 Z M11,6 L15,6 L15,9 L11,9 Z M5,11 L9,11 L9,14 L5,14 Z M11,11 L15,11 L15,14 L11,14 Z</StreamGeometry>
    <StreamGeometry x:Key="IconSplit">M2,2 L9,2 L9,9 L2,9 Z M11,2 L18,2 L18,9 L11,9 Z M2,11 L9,11 L9,18 L2,18 Z M11,11 L18,11 L18,18 L11,18 Z</StreamGeometry>
    <StreamGeometry x:Key="IconMonitor">M2,3 L18,3 L18,14 L11,14 L11,17 L15,17 L15,19 L5,19 L5,17 L9,17 L9,14 L2,14 Z</StreamGeometry>
    <StreamGeometry x:Key="IconConnect">M3,10 L11,10 M8,6 L12,10 L8,14 M13,4 L18,4 L18,16 L13,16</StreamGeometry>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme DensityStyle="Compact" />
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Noto Sans CJK SC, Noto Sans, Segoe UI" />
      <Setter Property="Background" Value="{StaticResource CanvasBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="TextBox, ComboBox">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="13,6" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#B84038" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.tool, ToggleButton.tool">
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="40" />
      <Setter Property="MinWidth" Value="40" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="10" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#F2F5F3" />
      <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="Button.tool:pointerover /template/ ContentPresenter, ToggleButton.tool:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource ToolbarHoverBrush}" />
    </Style>
    <Style Selector="ToggleButton.tool:checked /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    </Style>
    <Style Selector="PathIcon.toolbarIcon">
      <Setter Property="Width" Value="20" />
      <Setter Property="Height" Value="20" />
      <Setter Property="Foreground" Value="#F2F5F3" />
    </Style>
    <Style Selector="ToggleButton.fieldIcon">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="2" />
    </Style>
    <Style Selector="Border.statusPill">
      <Setter Property="Background" Value="#D91A211E" />
      <Setter Property="BorderBrush" Value="#46534E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="9,6" />
    </Style>
  </Application.Styles>
</Application>
